{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metaplus.dev/json-schemas/base.json",
  "title": "MetaplusBase",
  "description": "Shared reusable schema definitions for identity, metadata envelopes, query fragments, scripts, and patch results.",
  "$defs": {
    "scalar": {
      "description": "A primitive value allowed in generic filters, sort values, and script parameters.",
      "type": ["string", "number", "boolean", "null"]
    },
    "domains": {
      "description": "A list of domain names used to scope multi-domain requests.",
      "type": "array",
      "items": {"type": "string"}
    },
    "atTime": {
      "description": "Canonical UTC timestamp represented as an RFC 3339 date-time string.",
      "type": "string",
      "format": "date-time"
    },
    "byName": {
      "description": "Human or agent identifier that performed an operation.",
      "type": "string",
      "minLength": 1
    },

    "idea": {
      "description": "Stable identity section of a Metaplus document, carrying FQMN and its decomposed parts.",
      "type": "object",
      "properties": {
        "fqmn": {
          "description": "Fully qualified metadata name: <domain>:<system>:<instance>:<entity>.",
          "type": "string",
          "pattern": "^[^:]+:[^:]+:[^:]+:[^:]+$"
        },
        "domain": {
          "description": "Logical domain name used to partition metadata and runtime operations. The domain may use dot-separated taxonomy such as data.table.",
          "type": "string",
          "pattern": "^[a-z0-9._-]+$",
          "maxLength": 100
        },
        "system": {
          "description": "Source system name that owns or synchronizes the metadata.",
          "type": "string",
          "pattern": "^[a-z0-9._-]+$",
          "maxLength": 100
        },
        "instance": {
          "description": "Instance name within the source system, such as an environment, cluster, or account.",
          "type": "string",
          "pattern": "^[a-z0-9._-]+$",
          "maxLength": 100
        },
        "entity": {
          "description": "Entity identifier within the source instance, for example a table, topic, or model path.",
          "type": "string",
          "pattern": "^[a-zA-Z0-9._\\-+,~|@(){}\\[\\]]+$",
          "maxLength": 300
        }
      },
      "required": ["fqmn", "domain", "system", "instance", "entity"],
      "additionalProperties": true
    },
    "edit": {
      "description": "Document-level edit bookkeeping for meta and plus sections.",
      "type": "object",
      "properties": {
        "meta": {
          "type": "object",
          "properties": {
            "version": {
              "type": "integer"
            },
            "createdAt": {
              "$ref": "#/$defs/atTime"
            },
            "createdBy": {
              "$ref": "#/$defs/byName"
            },
            "updatedAt": {
              "$ref": "#/$defs/atTime"
            },
            "updatedBy": {
              "$ref": "#/$defs/byName"
            },
            "deletedAt": {
              "$ref": "#/$defs/atTime"
            },
            "deletedBy": {
              "$ref": "#/$defs/byName"
            },
            "restoredAt": {
              "$ref": "#/$defs/atTime"
            },
            "restoredBy": {
              "$ref": "#/$defs/byName"
            }
          }
        },
        "plus": {
          "type": "object",
          "properties": {
            "version": {
              "type": "integer"
            },
            "updatedAt": {
              "$ref": "#/$defs/atTime"
            },
            "updatedBy": {
              "$ref": "#/$defs/byName"
            }
          }
        }
      }
    },
    "query": {
      "description": "Reusable query fragment compatible with the supported Metaplus search and patch APIs.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "term": {
              "type": "object",
              "minProperties": 1,
              "maxProperties": 1,
              "additionalProperties": {
                "$ref": "#/$defs/scalar"
              }
            }
          },
          "required": ["term"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "terms": {
              "type": "object",
              "minProperties": 1,
              "maxProperties": 1,
              "additionalProperties": {
                "type": "array",
                "items": { "$ref": "#/$defs/scalar" },
                "minItems": 1
              }
            }
          },
          "required": ["terms"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "match": {
              "type": "object",
              "minProperties": 1,
              "maxProperties": 1,
              "additionalProperties": {
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "properties": {
                      "query": { "type": "string" },
                      "operator": { "enum": ["and", "or"] }
                    },
                    "required": ["query"],
                    "additionalProperties": true
                  }
                ]
              }
            }
          },
          "required": ["match"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "range": {
              "type": "object",
              "minProperties": 1,
              "maxProperties": 1,
              "additionalProperties": true
            }
          },
          "required": ["range"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "exists": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["field"],
              "additionalProperties": false
            }
          },
          "required": ["exists"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "bool": {
              "type": "object",
              "properties": {
                "must": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/query" }
                },
                "filter": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/query" }
                },
                "should": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/query" }
                },
                "must_not": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/query" }
                },
                "minimum_should_match": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string" }
                  ]
                }
              },
              "additionalProperties": false,
              "anyOf": [
                { "required": ["must"] },
                { "required": ["filter"] },
                { "required": ["should"] },
                { "required": ["must_not"] }
              ]
            }
          },
          "required": ["bool"],
          "additionalProperties": false
        }
      ]
    },
    "script": {
      "description": "Reusable script payload for patch-style operations.",
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "lang": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "options": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false,
      "oneOf": [
        { "required": ["source"] },
        { "required": ["id"] }
      ]
    },
    "result": {
      "description": "Normalized result counters returned by write and delete style operations.",
      "properties": {
        "innerId": { "type": "string" },
        "innerVersion": { "type": "integer" },
        "created": { "type": "integer" },
        "updated": { "type": "integer" },
        "deleted": { "type": "integer" },
        "noops": { "type": "integer" },
        "notFound": { "type": "integer" },
        "total": { "type": "integer" }
      }
    }
  }
}
