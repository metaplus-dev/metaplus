{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metaplus.dev/json-schemas/agg_request.json",
  "title": "AggRequest",
  "description": "Aggregation API request payload.",
  "type": "object",
  "properties": {
    "domain": {
      "description": "Target domain for the aggregation request.",
      "$ref": "base.json#/$defs/domain"
    },
    "query": {
      "description": "Optional filter applied before aggregations are computed.",
      "$ref": "base.json#/$defs/query"
    },
    "aggs": {
      "description": "Named aggregation definitions to execute.",
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/agg" }
    }
  },
  "$defs": {
    "agg": {
      "title": "AggregationDefinition",
      "description": "Supported aggregation clause, optionally nested with sub-aggregations.",
      "type": "object",
      "minProperties": 1,
      "properties": {
        "terms": {
          "type": "object",
          "properties": {
            "field": { "type": "string" },
            "size": { "type": "integer", "minimum": 1 },
            "order": {
              "type": "object",
              "additionalProperties": {
                "enum": ["asc", "desc"]
              }
            }
          },
          "required": ["field"],
          "additionalProperties": true
        },

        "date_histogram": {
          "type": "object",
          "properties": {
            "field": { "type": "string" },
            "calendar_interval": { "type": "string" },
            "fixed_interval": { "type": "string" }
          },
          "required": ["field"],
          "additionalProperties": true
        },

        "avg": {
          "type": "object",
          "properties": {
            "field": { "type": "string" }
          },
          "required": ["field"],
          "additionalProperties": false
        },

        "sum": {
          "type": "object",
          "properties": {
            "field": { "type": "string" }
          },
          "required": ["field"],
          "additionalProperties": false
        },

        "max": {
          "type": "object",
          "properties": {
            "field": { "type": "string" }
          },
          "required": ["field"],
          "additionalProperties": false
        },

        "min": {
          "type": "object",
          "properties": {
            "field": { "type": "string" }
          },
          "required": ["field"],
          "additionalProperties": false
        },

        "value_count": {
          "type": "object",
          "properties": {
            "field": { "type": "string" }
          },
          "required": ["field"],
          "additionalProperties": false
        },

        "filter": {
          "type": "object",
          "properties": {
            "query": { "$ref": "base.json#/$defs/query" }
          },
          "required": ["query"],
          "additionalProperties": false
        },

        "filters": {
          "type": "object",
          "properties": {
            "filters": {
              "type": "object",
              "additionalProperties": {
                "$ref": "base.json#/$defs/query"
              }
            }
          },
          "required": ["filters"],
          "additionalProperties": false
        },

        "top_hits": {
          "type": "object",
          "properties": {
            "size": { "type": "integer", "minimum": 1 },
            "sort": { "type": "array" }
          },
          "additionalProperties": true
        },

        "aggs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/agg"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
