{
  "mappings": {
    "dynamic": false,
    "dynamic_templates": [
      {
        "idea_strings_as_keyword": {
          "path_match": "idea.*",
          "match_mapping_type": "string",
          "mapping": {"type": "keyword"}
        }
      }
    ],
    "properties": {
      "idea": {
        "dynamic": true,
        "properties": {
          "fqmn": {"type": "keyword"},
          "domain": {"type": "keyword"},
          "system": {"type": "keyword"},
          "instance": {"type": "keyword"},
          "entity": {"type": "keyword"}
        }
      },
      "upsertedAt": {
        "type": "date"
      },
      "deletedAt": {
        "type": "date"
      },
      "lastSamplingAt": {
        "type": "date"
      },
      "lastLlmGenAt": {
        "type": "date"
      }
    }
  }
}
