{
  "settings": {
    "index": {
      "refresh_interval": "5s"
    }
  },
  "mappings": {
    "dynamic": false,
    "dynamic_templates": [
      {
        "idea_strings_as_keyword": {
          "path_match": "idea.*",
          "match_mapping_type": "string",
          "mapping": {"type": "keyword"}
        }
      }
    ],
    "properties": {
      "idea": {
        "dynamic": true,
        "properties": {
          "fqmn": {"type": "keyword"},
          "domain": {"type": "keyword"},
          "system": {"type": "keyword"},
          "instance": {"type": "keyword"},
          "entity": {"type": "keyword"}
        }
      },
      "data": {
        "type": "object",
        "enabled": false
      },
      "createdAt": {
        "type": "date"
      },
      "locked": {
        "type": "boolean"
      }
    }
  }
}
