{
  "settings": {
    "index": {
      "refresh_interval": "5s"
    }
  },
  "mappings": {
    "dynamic": false,
    "properties": {
      "idea": {
        "dynamic": true,
        "dynamic_templates": [
          {
            "strings_as_keyword": {
              "match_mapping_type": "string",
              "mapping": {"type": "keyword"}
            }
          }
        ],
        "properties": {
          "fqmn": {"type": "keyword"},
          "domain": {"type": "keyword"},
          "system": {"type": "keyword"},
          "instance": {"type": "keyword"},
          "entity": {"type": "keyword"}
        }
      },
      "data": {
        "type": "object",
        "enabled": false
      },
      "createdAt": {
        "type": "date"
      },
      "locked": {
        "type": "boolean"
      }
    }
  }
}